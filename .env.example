# ============================================================
# SimpleiTech — AdSense Environment Configuration
# ============================================================
#
# NOTE: This file is a REFERENCE ONLY.
# Because the site is a static HTML project hosted on GitHub Pages,
# environment variables cannot be injected at build time.
# Instead, edit `assets/js/adsense-config.js` directly.
#
# If the project is ever migrated to a framework (Next.js, Vite, etc),
# these variables can be used as shown here.
#
# ============================================================

# Google AdSense Publisher ID
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# Enable / disable ads (true | false)
NEXT_PUBLIC_ADSENSE_ENABLED=true

# Auto Ads toggle
NEXT_PUBLIC_AUTO_ADS_ENABLED=true

# Manual ad-unit slot IDs (create these in the AdSense dashboard)
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_IN_ARTICLE=
